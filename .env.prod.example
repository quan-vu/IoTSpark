# Production env — copy to .env.prod and fill in real values (never commit .env.prod)
WP_SITE_URL=https://yourdomain.com
WP_SITE_TITLE=YourSite
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me
WP_ADMIN_EMAIL=admin@yourdomain.com

WP_API_USER=api-contributor
WP_API_PASSWORD=change_me
WP_API_EMAIL=contributor@yourdomain.com

WP_EDITOR_USER=editor
WP_EDITOR_PASSWORD=change_me
WP_EDITOR_EMAIL=editor@yourdomain.com

MYSQL_DATABASE=wordpress_db
MYSQL_USER=wpuser
MYSQL_PASSWORD=change_me
